# Google AI (Gemini) — https://aistudio.google.com/apikey
# 1순위 모델 실패·비 JSON 응답 시 GEMINI_FALLBACK_MODEL 로 한 번 더 시도
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# (선택) 주조 캐스팅 전용 1차 모델, 미지정 시 GEMINI_MODEL 과 동일
# GEMINI_CASTING_MODEL=gemini-3-flash-preview

# GitHub Personal Access Token (repo 권한 필요)
GITHUB_TOKEN=ghp_...

# GitHub 저장소 정보
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main

# Optional: Vercel Blob (로컬 개발 또는 Vercel Storage 연결 시)
# BLOB_READ_WRITE_TOKEN=

# Optional: Google Calendar → 사무실일정 (이번 주·다음 주만 API에 합침, GitHub 미저장)
# 끄려면: GOOGLE_CALENDAR_SYNC_ENABLED=false
#
# 부캘만 가져오기: 목록의 "캘린더 이름"과 정확히 일치 (OAuth/서비스계정에서 calendarList로 ID 자동 선택)
# GOOGLE_CALENDAR_SUBCALENDAR_SUMMARY=MBC충북
#
# --- 방법 0: API 키 — 캘린더를 반드시 "공개"로. 부캘만 쓰면 GOOGLE_CALENDAR_ID에 그 캘린더 ID(통합 캘린더) 직접 입력 ---
# GOOGLE_CALENDAR_ID=xxxx@group.calendar.google.com
# GOOGLE_CALENDAR_API_KEY=AIza...
#
# --- 방법 A: OAuth 리프레시 토큰 — 서비스 계정 키 불필요, 비공개 캘린더 가능 ---
# GCP에서 OAuth 클라이언트(웹), 리디렉션 URI: http://127.0.0.1:8765/oauth2callback
# Calendar API 사용 설정, 동의 화면에 calendar.readonly + 테스트 사용자 추가
# 로컬: npm run gcal:oauth  (CLIENT_ID/SECRET만 .env.local에 두고 실행)
# GOOGLE_CALENDAR_ID=office.todo.osm@gmail.com
# GOOGLE_CALENDAR_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=...
# GOOGLE_CALENDAR_OAUTH_REFRESH_TOKEN=...
#
# --- 방법 B: 서비스 계정 JSON 키(조직에서 키 생성이 막혀 있으면 A 사용) ---
# GOOGLE_CALENDAR_ID=공유한 캘린더 ID
# GOOGLE_CALENDAR_CLIENT_EMAIL=xxx@....iam.gserviceaccount.com
# GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
